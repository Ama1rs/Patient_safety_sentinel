{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Patient Safety Sentinel",
  "version": "0.1.0",
  "identifier": "com.amalrs.patientsafetysentinel",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "Patient Safety Sentinel",
        "width": 1600,
        "height": 980,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
